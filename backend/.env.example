# Vitto Backend Environment Variables

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=vitto
PG_USER=postgres
PG_PASSWORD=your_pg_password

# MongoDB
MONGO_URI=mongodb://localhost:27017/vitto

# JWT
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d
